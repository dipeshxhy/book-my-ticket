# App
PORT=8080
NODE_ENV=development
JWT_SECRET=replace-with-a-strong-secret

# CORS (comma-separated list of allowed origins)
# Example: FRONTEND_ORIGIN=https://your-app.onrender.com
FRONTEND_ORIGIN=

# Preferred: single URL for cloud Postgres (Neon/Render)
# Example: DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Optional DB SSL override (true/false)
DB_SSL=

# Alternative local DB config (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=book_my_show

# Optional pool tuning
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
